
name: Clone and Count Lines
on: workflow_dispatch
jobs:
  clone-and-count:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          repository: k0inwork/test
          token: \${{ secrets.GITHUB_TOKEN }}
      - name: Count all lines
        run: |
          echo "=== Line Count ==="
          find . -type f -not -path './.git/*' | while read -r file; do
            wc -l "$file"
          done > /tmp/line_counts.txt
          echo "=== Summary ==="
          cat /tmp/line_counts.txt
          TOTAL=$(find . -type f -not -path './.git/*' -exec cat {} + | wc -l)
          echo "Total lines: $TOTAL"
          echo "$TOTAL" > total_lines.txt
      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: line-count-results
          path: |
            total_lines.txt
            /tmp/line_counts.txt
